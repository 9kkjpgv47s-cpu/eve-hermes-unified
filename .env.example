# Source pinning
EVE_SOURCE_REMOTE=/Users/dominiceasterling/openclaw
EVE_SOURCE_REF=main
HERMES_SOURCE_REMOTE=https://github.com/NousResearch/hermes-agent.git
HERMES_SOURCE_REF=main

# Optional hard commit pins (when set, override *_REF)
EVE_SOURCE_COMMIT=
HERMES_SOURCE_COMMIT=

# Unified router defaults
UNIFIED_ROUTER_DEFAULT_PRIMARY=eve
UNIFIED_ROUTER_DEFAULT_FALLBACK=hermes
UNIFIED_ROUTER_FAIL_CLOSED=1
UNIFIED_ROUTER_STAGE=shadow
# Comma-separated chat IDs that always use Hermes as primary (even when stage is shadow).
UNIFIED_ROUTER_HERMES_PRIMARY_CHAT_IDS=
# Comma-separated chat IDs routed to Hermes in canary stage.
UNIFIED_ROUTER_CANARY_CHAT_IDS=
# Integer percent (0-100) of chats routed to Hermes in majority stage.
UNIFIED_ROUTER_MAJORITY_PERCENT=80
# Comma-separated failure_class tokens: skip fallback when primary fails with any listed class (dispatch layer).
UNIFIED_ROUTER_NO_FALLBACK_ON_FAILURE_CLASSES=
# Region label: when envelope.regionId matches, swap primary/fallback for failover drills (requires fallback lane).
UNIFIED_ROUTER_STANDBY_REGION=

# Eve lane wiring
EVE_TASK_DISPATCH_SCRIPT=/Users/dominiceasterling/openclaw/scripts/eve-task-dispatch.sh
EVE_DISPATCH_RESULT_PATH=/Users/dominiceasterling/.openclaw/state/eve-task-dispatch-last.json

# Hermes lane wiring (placeholder command)
HERMES_LAUNCH_COMMAND=python3
HERMES_LAUNCH_ARGS=-m hermes gateway

# Unified memory store defaults
UNIFIED_MEMORY_STORE_KIND=file
UNIFIED_MEMORY_FILE_PATH=/tmp/eve-hermes-unified-memory.json
# Serialize concurrent writes on the backing store (helps in-memory backends under overlap).
UNIFIED_MEMORY_SERIALIZE_WRITES=0

# Capability policy guardrails
# allow|deny (deny means only explicitly listed capabilities/chats may run)
UNIFIED_CAPABILITY_POLICY_DEFAULT=allow
# Comma-separated capability IDs allowed when policy default is deny
UNIFIED_CAPABILITY_ALLOWED_IDS=
# Comma-separated capability IDs always blocked
UNIFIED_CAPABILITY_DENIED_IDS=
# Comma-separated chat IDs allowed to run capability commands
UNIFIED_CAPABILITY_ALLOWED_CHAT_IDS=
# Comma-separated chat IDs blocked from running capability commands
UNIFIED_CAPABILITY_DENIED_CHAT_IDS=
# When UNIFIED_TENANT_ALLOWLIST is non-empty, ingress without a matching tenantId fails closed at dispatch.
UNIFIED_TENANT_ALLOWLIST=
UNIFIED_TENANT_DENYLIST=
# Capability invocation tenant scopes (allowedTenantIds is a strict allowlist when non-empty).
UNIFIED_CAPABILITY_ALLOWED_TENANT_IDS=
UNIFIED_CAPABILITY_DENIED_TENANT_IDS=
# JSON file backing the optional dispatch durability queue (see UNIFIED_DISPATCH_DURABILITY_QUEUE_PATH).
UNIFIED_DISPATCH_DURABILITY_QUEUE_PATH=/tmp/eve-hermes-unified-dispatch-queue.json
# Max dispatched/failed queue entries to retain (oldest dropped first). Pending entries are never pruned. 0 = unlimited.
UNIFIED_DISPATCH_DURABILITY_QUEUE_RETENTION_NON_TERMINAL_MAX=5000
# format: capability_id:chatA,chatB;other_capability:chatC
UNIFIED_CAPABILITY_PER_CAPABILITY_CHAT_ALLOWLIST=
UNIFIED_CAPABILITY_PER_CAPABILITY_CHAT_DENYLIST=

# Capability executor wall-clock budget (ms); omit or 0 for unlimited.
UNIFIED_CAPABILITY_EXECUTION_TIMEOUT_MS=

# Soak drift thresholds (scripts/summarize-soak-report.mjs); set UNIFIED_SOAK_SUMMARIZE=1 in soak-simulate.sh
# UNIFIED_SOAK_MIN_TRACE_RATE=0.95
# UNIFIED_SOAK_MIN_SUCCESS_RATE=0.85
# UNIFIED_SOAK_MAX_P95_ELAPSED_MS=60000
# UNIFIED_SOAK_FAIL_ON_DRIFT=0

# Dispatch audit JSONL rotation (optional; 0 = disabled)
UNIFIED_DISPATCH_AUDIT_ROTATION_MAX_BYTES=0
UNIFIED_DISPATCH_AUDIT_ROTATION_RETAIN_COUNT=8
# Append-only JSONL: each @cap policy authorization (allowed/denied + reason). Default: dirname(UNIFIED_AUDIT_LOG_PATH)/unified-capability-policy-audit.jsonl
UNIFIED_CAPABILITY_POLICY_AUDIT_LOG_PATH=
# Capability policy audit JSONL rotation (optional; 0 = disabled — matches historical H8 append-only behavior)
UNIFIED_CAPABILITY_POLICY_AUDIT_ROTATION_MAX_BYTES=0
UNIFIED_CAPABILITY_POLICY_AUDIT_ROTATION_RETAIN_COUNT=8

# Runtime safety and observability
UNIFIED_PREFLIGHT_ENABLED=1
UNIFIED_PREFLIGHT_STRICT=1
UNIFIED_AUDIT_LOG_PATH=/tmp/eve-hermes-unified-audit.jsonl
