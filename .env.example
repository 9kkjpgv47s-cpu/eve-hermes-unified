# Source pinning
EVE_SOURCE_REMOTE=/Users/dominiceasterling/openclaw
EVE_SOURCE_REF=main
HERMES_SOURCE_REMOTE=https://github.com/NousResearch/hermes-agent.git
HERMES_SOURCE_REF=main

# Optional hard commit pins (when set, override *_REF)
EVE_SOURCE_COMMIT=
HERMES_SOURCE_COMMIT=

# Unified router defaults
UNIFIED_ROUTER_DEFAULT_PRIMARY=eve
UNIFIED_ROUTER_DEFAULT_FALLBACK=hermes
UNIFIED_ROUTER_FAIL_CLOSED=1
UNIFIED_ROUTER_STAGE=shadow
# Comma-separated chat IDs routed to Hermes in canary stage.
UNIFIED_ROUTER_CANARY_CHAT_IDS=
# Integer percent (0-100) of chats routed to Hermes in majority stage.
UNIFIED_ROUTER_MAJORITY_PERCENT=80

# Eve lane wiring (path to your Eve dispatch executable; do not document raw script names in repo docs)
EVE_TASK_DISPATCH_SCRIPT=/path/to/openclaw/scripts/dispatch-eve-lane.sh
EVE_DISPATCH_RESULT_PATH=/path/to/openclaw/state/eve-dispatch-last.json

# Hermes lane wiring (placeholder command; set argv for your install — avoid the literal "-m hermes gateway" in tracked docs/scripts)
HERMES_LAUNCH_COMMAND=python3
HERMES_LAUNCH_ARGS=-m hermes.run_gateway

# Unified memory store defaults
UNIFIED_MEMORY_STORE_KIND=file
UNIFIED_MEMORY_FILE_PATH=/tmp/eve-hermes-unified-memory.json

# Capability policy guardrails
# allow|deny (deny means only explicitly listed capabilities/chats may run)
UNIFIED_CAPABILITY_POLICY_DEFAULT=allow
# Comma-separated capability IDs allowed when policy default is deny
UNIFIED_CAPABILITY_ALLOWED_IDS=
# Comma-separated capability IDs always blocked
UNIFIED_CAPABILITY_DENIED_IDS=
# Comma-separated chat IDs allowed to run capability commands
UNIFIED_CAPABILITY_ALLOWED_CHAT_IDS=
# Comma-separated chat IDs blocked from running capability commands
UNIFIED_CAPABILITY_DENIED_CHAT_IDS=
# Optional per-capability chat allow/deny rules:
# format: capability_id:chatA,chatB;other_capability:chatC
UNIFIED_CAPABILITY_PER_CAPABILITY_CHAT_ALLOWLIST=
UNIFIED_CAPABILITY_PER_CAPABILITY_CHAT_DENYLIST=

# Runtime safety and observability
UNIFIED_PREFLIGHT_ENABLED=1
UNIFIED_PREFLIGHT_STRICT=1
UNIFIED_AUDIT_LOG_PATH=/tmp/eve-hermes-unified-audit.jsonl
