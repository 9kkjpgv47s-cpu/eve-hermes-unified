# Source pinning
EVE_SOURCE_REMOTE=/Users/dominiceasterling/openclaw
EVE_SOURCE_REF=main
HERMES_SOURCE_REMOTE=https://github.com/NousResearch/hermes-agent.git
HERMES_SOURCE_REF=main

# Optional hard commit pins (when set, override *_REF)
EVE_SOURCE_COMMIT=
HERMES_SOURCE_COMMIT=

# Unified router defaults
UNIFIED_ROUTER_DEFAULT_PRIMARY=eve
UNIFIED_ROUTER_DEFAULT_FALLBACK=hermes
UNIFIED_ROUTER_FAIL_CLOSED=1
UNIFIED_ROUTER_POLICY_VERSION=v1

# Ingress gateway (Phase 1): unified = dispatch once; legacy = skip dispatch (cutover flag)
UNIFIED_TELEGRAM_GATEWAY_MODE=unified

# Lane timeouts (milliseconds)
EVE_LANE_TIMEOUT_MS=180000
HERMES_LANE_TIMEOUT_MS=180000

# Evidence bundle output directory (gateway writes JSON transcripts here)
UNIFIED_EVIDENCE_DIR=

# Working-set memory: memory (default) or file-backed JSON under repo
UNIFIED_MEMORY_BACKEND=memory
UNIFIED_MEMORY_FILE_PATH=memory/unified-memory.json

# When 1, reject ambiguous router env values at startup (stricter control plane)
UNIFIED_STRICT_CONFIG=0

# Telegram Bot API webhook server (`npm run webhook:telegram`)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8787

# Suppress stderr deprecation notices for legacy env names (tests/CI)
# UNIFIED_SUPPRESS_LEGACY_WARNINGS=1

# Legacy env shims (used only when canonical name above is unset)
# EVE_DISPATCH_SCRIPT=
# EVE_RESULT_PATH=
# HERMES_CMD=
# ROUTER_PRIMARY=
# ROUTER_FALLBACK=
# ROUTER_FAIL_CLOSED=
EVE_TASK_DISPATCH_SCRIPT=/Users/dominiceasterling/openclaw/scripts/eve-task-dispatch.sh
EVE_DISPATCH_RESULT_PATH=/Users/dominiceasterling/.openclaw/state/eve-task-dispatch-last.json

# Hermes lane wiring (placeholder command)
HERMES_LAUNCH_COMMAND=python3
HERMES_LAUNCH_ARGS=-m hermes gateway
