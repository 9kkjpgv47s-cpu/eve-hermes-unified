{
  "name": "eve-hermes-unified",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dispatch": "tsx src/bin/unified-dispatch.ts",
    "sync:sources": "bash ./scripts/sync-sources.sh",
    "bootstrap:sources": "bash ./scripts/bootstrap-sources.sh",
    "validate:failure-injection": "bash ./scripts/failure-injection-smoke.sh",
    "validate:soak": "bash ./scripts/soak-simulate.sh 20",
    "validate:evidence-summary": "bash ./scripts/validate-evidence-summary.sh",
    "validate:evidence-gates": "node ./scripts/evidence-gates.mjs",
    "validate:horizon-status": "node ./scripts/validate-horizon-status.mjs --file ./docs/HORIZON_STATUS.json",
    "validate:horizon-closeout": "node ./scripts/validate-horizon-closeout.mjs",
    "validate:h2-closeout": "node ./scripts/validate-horizon-closeout.mjs --horizon H2 --next-horizon H3 --require-completed-actions",
    "check:progressive-horizon-goals": "node ./scripts/check-progressive-horizon-goals.mjs",
    "check:goal-policy-coverage": "node ./scripts/check-goal-policy-coverage.mjs",
    "audit:goal-policy-readiness": "node ./scripts/audit-goal-policy-readiness.mjs",
    "validate:goal-policy-file": "node ./scripts/validate-goal-policy-file.mjs --horizon-status-file ./docs/HORIZON_STATUS.json --goal-policy-file ./docs/GOAL_POLICIES.json --source-horizon H2 --until-horizon H5 --require-tagged-requirements --require-positive-pending-min --out ./evidence/goal-policy-file-validation.json",
    "promote:horizon": "node ./scripts/promote-horizon.mjs",
    "run:h2-closeout": "node ./scripts/run-h2-closeout.mjs",
    "run:h2-promotion": "node ./scripts/run-h2-promotion.mjs",
    "evaluate:auto-rollback-policy": "node ./scripts/evaluate-auto-rollback-policy.mjs",
    "calibrate:rollback-thresholds": "node ./scripts/calibrate-rollback-thresholds.mjs",
    "run:supervised-rollback-simulation": "node ./scripts/run-supervised-rollback-simulation.mjs",
    "run:stage-drill": "node ./scripts/run-stage-drill.mjs",
    "run:h2-drill-suite": "node ./scripts/run-h2-drill-suite.mjs",
    "validate:manifest-schema": "node ./scripts/validate-manifest-schema.mjs",
    "verify:merge-bundle": "node ./scripts/verify-merge-bundle.mjs",
    "check:stage-promotion-readiness": "node ./scripts/check-stage-promotion-readiness.mjs",
    "check:stage-promotion": "npm run check:stage-promotion-readiness",
    "promote:stage": "node ./scripts/promote-cutover-stage.mjs",
    "validate:manifest-schemas": "node ./scripts/validate-manifest-schema.mjs --type all --evidence-dir ./evidence --latest-only",
    "validate:regression-eve": "bash ./scripts/regression-eve-primary.sh",
    "validate:regression-eve-primary": "npm run validate:regression-eve",
    "validate:cutover-readiness": "bash ./scripts/verify-cutover-readiness.sh",
    "validate:release-readiness": "bash ./scripts/validate-release-readiness.sh",
    "validate:initial-scope": "bash ./scripts/validate-initial-scope.sh",
    "validate:all": "npm run check && npm test && npm run build && npm run validate:failure-injection && npm run validate:soak && npm run validate:evidence-summary && npm run validate:regression-eve && npm run validate:cutover-readiness",
    "validate:merge-bundle": "bash ./scripts/validate-merge-bundle.sh",
    "bundle:merge-readiness": "node ./scripts/build-merge-readiness-bundle.mjs",
    "test:cutover-scripts": "vitest run test/cutover-scripts.test.ts",
    "cutover:stage": "bash ./scripts/prod-cutover-stage.sh",
    "cutover:rollback": "bash ./scripts/prod-rollback-eve-safe-lane.sh"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
